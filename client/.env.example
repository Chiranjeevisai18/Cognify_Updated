# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Your Clerk publishable key
# - For development:  pk_test_... (from Clerk Dashboard > API Keys)
# - For production:   pk_live_... (from Clerk Dashboard > API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx

# Your deployed backend URL (no trailing slash)
# - For development:  http://localhost:5000
# - For production:   https://your-service-name.onrender.com
VITE_API_BASE_URL=https://your-service-name.onrender.com
